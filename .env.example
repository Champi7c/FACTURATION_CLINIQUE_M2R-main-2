# ============================================
# Facturation Clinique - Variables d'environnement
# ============================================
# Copier vers .env et adapter les valeurs.
# Ne jamais commiter .env (déjà dans .gitignore).

# ---------- Ports (éviter 3000, 3001, 3002, 8000, 8001, 8080, 8086, 3317, 3318)
FRONTEND_PORT=9000
BACKEND_PORT=9001
PHPMYADMIN_PORT=9002
MYSQL_PORT=9330

# ---------- Docker Registry (pour CI/CD et images)
DOCKER_REGISTRY=devcgfbourse
IMAGE_TAG=latest

# ---------- Django
SECRET_KEY=changez-moi-en-production-une-cle-secrete-longue-et-aleatoire
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,72.62.29.141,backend

# ---------- Base de données MySQL
DB_NAME=facturation_clinique
DB_USER=root
DB_PASSWORD=changez-moi-mot-de-passe-mysql

# ---------- CORS (URL du frontend telle que vue par le navigateur)
CORS_ALLOWED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000,http://72.62.29.141:9000,https://72.62.29.141:9000

# ---------- Frontend build : URL de l'API (telle que le navigateur l'appelle)
REACT_APP_API_BASE_URL=http://72.62.29.141:9001/api

# ---------- Optionnel (cookies, SSL derrière reverse proxy)
