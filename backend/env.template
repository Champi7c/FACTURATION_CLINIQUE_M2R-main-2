# Django Configuration
SECRET_KEY=django-insecure-change-this-in-production-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
# Pour développer SANS MySQL (base SQLite locale), décommentez la ligne suivante :
USE_SQLITE=True

# Si vous utilisez MySQL (Docker ou installé) :
# USE_SQLITE=False
# DB_HOST=127.0.0.1
# DB_NAME=facturation_clinique
# DB_USER=root
# DB_PASSWORD=rootpassword
# DB_ROOT_PASSWORD=rootpassword
# DB_PORT=3306
DB_HOST=db
DB_NAME=facturation_clinique
DB_USER=root
DB_PASSWORD=rootpassword
DB_ROOT_PASSWORD=rootpassword
DB_PORT=3317

# CORS Configuration (optionnel, pour le frontend)
# Ajoutez les URLs de votre frontend (séparées par des virgules)
# Exemple pour production: http://72.62.29.141:3000,http://votre-domaine.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://72.62.29.141:3000

# Pour le développement uniquement: autoriser toutes les origines (moins sécurisé)
# CORS_ALLOW_ALL_ORIGINS=True

# phpMyAdmin Configuration
PHPMYADMIN_PORT=8080

